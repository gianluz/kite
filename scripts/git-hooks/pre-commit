#!/bin/sh
#
# Git pre-commit hook — Version reference synchronization
#
# When build.gradle.kts is modified (version bump), ensures that ALL tracked
# files (README, docs, install.sh, plugin READMEs, etc.) are updated before
# the commit is accepted.
#
# To install:  ./gradlew build  (hooks install automatically)
# To bypass:   git commit --no-verify  (use sparingly)
#

# Only run if root build.gradle.kts (not a subproject one) is staged
CHANGED_FILES=$(git diff --cached --name-only)

if echo "$CHANGED_FILES" | grep -q "^build.gradle.kts$"; then
    echo "🔍 build.gradle.kts changed — checking all version references..."

    # Build the CLI if not already present
    if [ ! -f "kite-cli/build/install/kite-cli/bin/kite-cli" ]; then
        echo "📦 Building Kite CLI first..."
        JAVA_HOME=${JAVA_HOME:-$(java -XshowSettings:all -version 2>&1 | grep java.home | awk '{print $3}' | sed 's|/jre||')}
        ./gradlew :kite-cli:installDist --quiet --no-daemon > /dev/null 2>&1
        if [ $? -ne 0 ]; then
            echo "❌ Failed to build Kite CLI. Commit blocked."
            exit 1
        fi
    fi

    KITE="kite-cli/build/install/kite-cli/bin/kite-cli"

    # Run full version-sync check (checks ALL tracked files)
    CHECK_OUTPUT=$($KITE run check-version-sync 2>&1)
    CHECK_EXIT=$?

    # Strip JVM/tooling noise
    FILTERED=$(echo "$CHECK_OUTPUT" | grep -v "^Picked up\|^OpenJDK\|^WARNING:")

    if [ $CHECK_EXIT -eq 0 ]; then
        echo "✅ All version references are in sync!"
    else
        if echo "$FILTERED" | grep -q "out of sync\|Version references"; then
            echo ""
            echo "$FILTERED"
            echo ""
            echo "─────────────────────────────────────────────────────"
            echo "💡 Auto-fix: run the following, then re-commit"
            echo ""
            echo "   $KITE run update-version-refs"
            echo "   git add -A"
            echo ""
            echo "⚠️  To skip this check (not recommended):"
            echo "   git commit --no-verify"
            echo ""
            exit 1
        else
            # Unexpected error — show output but don't block commit
            echo ""
            echo "$FILTERED"
            echo ""
            echo "⚠️  Version check encountered an unexpected error (shown above)."
            echo "   To bypass: git commit --no-verify"
            echo ""
            exit 1
        fi
    fi
fi

exit 0
